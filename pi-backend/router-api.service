[Unit]
Description=Travel Router API
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/travel-router-admin/pi-backend
Environment=PATH=/opt/travel-router-admin/pi-backend/venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
ExecStart=/opt/travel-router-admin/pi-backend/venv/bin/python -m uvicorn src.main:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target