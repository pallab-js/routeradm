# REQUIRED: Generate a secure token (e.g., openssl rand -hex 32)
SECRET_TOKEN=your-secure-token-here

# REQUIRED: Set a strong password (min 12 characters)
ADMIN_PASSWORD=your-secure-password-here

# Optional settings
API_HOST=0.0.0.0
API_PORT=8080
LOG_LEVEL=INFO
WIFI_INTERFACE=wlan0
WAN_INTERFACE=eth0

# Wi-Fi country code (ISO 3166-1 alpha-2). Change to your region (e.g., DE, GB, JP, AU)
WIFI_COUNTRY_CODE=US

# Allow HTTP for local development only (NOT recommended for production)
ALLOW_HTTP=false

# Comma-separated list of allowed CORS origins
# ALLOWED_ORIGINS=http://localhost:3000,travel-router-admin://