{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "TravelRouter Admin",
  "version": "0.1.0",
  "identifier": "com.travelrouter.admin",
  "build": {
    "frontendDist": "../frontend/out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": {
      "script": "npm run dev",
      "cwd": "..",
      "wait": false
    },
    "beforeBuildCommand": {
      "script": "npm run build",
      "cwd": ".."
    }
  },
  "app": {
    "windows": [
      {
        "title": "TravelRouter Admin",
        "width": 1024,
        "height": 720,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "11.0",
      "entitlements": "macos/entitlements.plist"
    }
  }
}